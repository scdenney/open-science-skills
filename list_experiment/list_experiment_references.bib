% SOFTWARE
% -----------------------------------------------------------------------

@manual{blairlist,
  author    = {Blair, Graeme and Chou, Winston and Imai, Kosuke},
  title     = {\texttt{list}: {Statistical} Methods for the Item Count Technique and List Experiment},
  year      = {2025},
  note      = {R package version 9.2.6},
  url       = {https://CRAN.R-project.org/package=list}
}
% Summary: Standard R package implementing all major list experiment estimators, including
% difference-in-means, NLSreg and MLreg multivariate regression (Imai 2011; Blair & Imai 2012),
% combined direct-question estimators (Aronow et al. 2015), and measurement-error models
% (Blair et al. 2019). Includes placebo diagnostic tests and Bayesian MCMC hierarchical models.
